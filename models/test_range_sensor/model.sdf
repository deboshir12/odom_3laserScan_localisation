<?xml version="1.0"?>
<sdf version="1.12">
  <model name="test_range_sensor">
    <static>true</static>

    <link name="sensor_link">
      <pose>0.3 0 0.2 0 0 0</pose>

      <visual name="visual">
        <geometry>
          <box>
            <size>0.05 0.05 0.05</size>
          </box>
        </geometry>
      </visual>

      <collision name="collision">
        <geometry>
          <box>
            <size>0.05 0.05 0.05</size>
          </box>
        </geometry>
      </collision>

      <sensor name="front_sensor" type="ray">
        <always_on>true</always_on>
        <visualize>true</visualize>
        <update_rate>10</update_rate>
        <topic>/range_front_raw</topic>

        <ray>
          <scan>
            <horizontal>
                <samples>360</samples>
                <resolution>1</resolution>
                <min_angle>0.000000</min_angle>
                <max_angle>6.280000</max_angle>
            </horizontal>
          </scan>

          <range>
            <min>0.12</min>
            <max>10</max>
            <resolution>0.01</resolution>
          </range>
        </ray>
      </sensor>
    </link>
  </model>
</sdf>