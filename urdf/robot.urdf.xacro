<?xml version="1.0"?>
<robot name="my_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Параметры -->
  <xacro:property name="base_length" value="0.4"/>
  <xacro:property name="base_width" value="0.4"/>
  <xacro:property name="base_height" value="0.2"/>

  <xacro:property name="wheel_radius" value="0.03"/>
  <xacro:property name="mass_base" value="5.00"/>
  <xacro:property name="wheel_width" value="0.02"/>
  <xacro:property name="wheel_y_offset" value="0.21"/>

  <material name="robot_blue">
    <color rgba="0.2 0.4 1 1"/>
  </material>
  <material name="robot_gray">
    <color rgba="0.7 0.7 0.7 1"/>
  </material>

  <!-- База -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    <material name="robot_gray"/>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="${mass_base}"/>
      <inertia
        ixx="0.0208"
        ixy="0.0"
        ixz="0.0"
        iyy="0.0283"
        iyz="0.0"
        izz="0.0417"/>
    </inertial>
  </link>

  <link name="base_footprint">
  </link>
  <joint name="base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_footprint"/>
    <origin xyz="0.0 0.0 ${-(base_height/2 + wheel_radius/2)}" rpy="0 0 0"/>
  </joint>

  <!-- Макрос колеса -->
  <xacro:macro name="wheel" params="name y_offset">
    <link name="${name}">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </visual>

      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.2"/>
        <inertia
          ixx="0.00013"
          ixy="0.0"
          ixz="0.0"
          iyy="0.00013"
          iyz="0.0"
          izz="0.00025"/>
      </inertial>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="0 ${y_offset} ${- base_height/2 + wheel_radius/2}" rpy="0 1.57 1.57"/>
      <axis xyz="0 0 1"/>
    </joint>
  </xacro:macro>


  <xacro:macro name="range_sensor_mount" params="name x y z roll pitch yaw topic_name">
  <link name="${name}">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
      <material name="robot_blue"/>
    </visual>

    <collision>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.01"/>
      <inertia
        ixx="1e-6" ixy="0" ixz="0"
        iyy="1e-6" iyz="0"
        izz="1e-6"/>
    </inertial>
  </link>

  <joint name="${name}_joint" type="fixed">
    <parent link="base_link"/>
    <child link="${name}"/>
    <origin xyz="${x} ${y} ${z}" rpy="${roll} ${pitch} ${yaw}"/>
  </joint>
</xacro:macro>

  <xacro:macro name="support_wheel" params="name x y z">
    <link name="${name}">
      <visual>
        <geometry>
          <sphere radius="0.03"/>
        </geometry>
        <material name="robot_gray"/>
      </visual>

      <collision>
        <geometry>
          <sphere radius="0.03"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="0.05"/>
        <inertia
          ixx="1e-5"
          ixy="0.0"
          ixz="0.0"
          iyy="1e-5"
          iyz="0.0"
          izz="1e-5"/>
      </inertial>
    </link>

    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${x} ${y} ${z}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <!-- Sensors -->
  <xacro:range_sensor_mount name="range_front" x="0.21" y="0.0" z="0.05" roll="0" pitch="0" yaw="0" topic_name="/range_front_raw"/>
  <xacro:range_sensor_mount name="range_left"  x="0.00" y="0.21" z="0.05" roll="0" pitch="0" yaw="1.5708" topic_name="/range_left_raw"/>
  <xacro:range_sensor_mount name="range_right" x="0.00" y="-0.21" z="0.05" roll="0" pitch="0" yaw="-1.5708" topic_name="/range_right_raw"/>

  <!-- Колёса -->
  <xacro:wheel name="left_wheel" y_offset="${wheel_y_offset}"/>
  <xacro:wheel name="right_wheel" y_offset="-${wheel_y_offset}"/>

  <xacro:support_wheel name="front_support_wheel" x="${wheel_y_offset/2}" y="0" z="${- base_height/2 + wheel_radius/2}"/>
  <xacro:support_wheel name="back_support_wheel" x="${- wheel_y_offset/2}" y="0" z="${- base_height/2 + wheel_radius/2}"/>

  <gazebo>
    <plugin
        filename="gz-sim-diff-drive-system"
        name="gz::sim::systems::DiffDrive">

      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>

      <wheel_separation>0.42</wheel_separation>
      <wheel_radius>0.03</wheel_radius>

      <odom_publish_frequency>50</odom_publish_frequency>

      <topic>/cmd_vel</topic>
      <odom_topic>model/diff_drive/odometry</odom_topic>
      <tf_topic>model/diff_drive/pose</tf_topic>

      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      
      <min_linear_velocity>-1.0</min_linear_velocity>
      <max_linear_velocity>1.0</max_linear_velocity>

      <min_angular_velocity>-2.0</min_angular_velocity>
      <max_angular_velocity>2.0</max_angular_velocity>

      <min_linear_acceleration>-1.0</min_linear_acceleration>
      <max_linear_acceleration>1.0</max_linear_acceleration>

      <min_angular_acceleration>-2.0</min_angular_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
    </plugin>
    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
      <topic>/world/Depot/model/diff_drive/joint_state</topic>
    </plugin>
    <plugin
      filename="gz-sim-pose-publisher-system"
      name="gz::sim::systems::PosePublisher">
      <publish_link_pose>true</publish_link_pose>
      <use_pose_vector_msg>true</use_pose_vector_msg>
      <static_publisher>true</static_publisher>
      <static_update_frequency>1</static_update_frequency>
    </plugin>
  </gazebo>

  <gazebo reference="range_front">
    <sensor name="range_front_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>range_front</topic>

      <lidar>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.05</min>
          <max>15.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>

      <plugin name="dummy" filename="dummyfile"/>
    </sensor>
  </gazebo>

  <gazebo reference="range_left">
    <sensor name="range_left_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>range_left</topic>

      <lidar>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.05</min>
          <max>15.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>

      <plugin name="dummy" filename="dummyfile"/>
    </sensor>
  </gazebo>

  <gazebo reference="range_right">
    <sensor name="range_right_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>range_right</topic>

      <lidar>
        <scan>
          <horizontal>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.05</min>
          <max>15.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>

      <plugin name="dummy" filename="dummyfile"/>
    </sensor>
  </gazebo>

  <xacro:macro name="lidar_sensor_mount" params="name x y z roll pitch yaw ">
    <link name="${name}">
      <visual>
        <geometry>
          <box size="0.02 0.02 0.02"/>
        </geometry>
        <material name="robot_blue"/>
      </visual>

      <collision>
        <geometry>
          <box size="0.02 0.02 0.02"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="0.01"/>
        <inertia
          ixx="1e-6" ixy="0" ixz="0"
          iyy="1e-6" iyz="0"
          izz="1e-6"/>
      </inertial>
    </link>

    <joint name="${name}_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${name}"/>
      <origin xyz="${x} ${y} ${z}" rpy="${roll} ${pitch} ${yaw}"/>
    </joint>
  </xacro:macro>
  <xacro:lidar_sensor_mount name="lidar_sensor" x="0.00" y="0" z="${base_height/2 + 0.01}" roll="0" pitch="0" yaw="0"/>
  <gazebo reference="lidar_sensor">
    <sensor name="range_lidar_sensor" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>range_lidar</topic>

      <lidar>
        <scan>  
          <horizontal>
            <samples>1000</samples>
            <resolution>1</resolution>
            <min_angle>0</min_angle>
            <max_angle>6.28</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.05</min>
          <max>20.0</max>
          <resolution>0.01</resolution>
        </range>
      </lidar>

      <plugin name="dummy" filename="dummyfile"/>
    </sensor>
  </gazebo>
</robot>

